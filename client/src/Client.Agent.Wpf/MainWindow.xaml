<Window x:Class="Client.Agent.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Manager Client Agent"
        Height="370"
        Width="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="ServerManagerBilling Client Agent"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,12" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Agent ID: " FontWeight="SemiBold" />
            <TextBlock x:Name="AgentIdTextBlock" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Connection: " FontWeight="SemiBold" />
            <TextBlock x:Name="ConnectionStatusTextBlock" Text="Disconnected" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Machine State: " FontWeight="SemiBold" />
            <TextBlock x:Name="MachineStateTextBlock" Text="LOCKED" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Last Command: " FontWeight="SemiBold" />
            <TextBlock x:Name="LastCommandTextBlock" Text="None" />
        </StackPanel>

        <Border Grid.Row="5"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="10"
                CornerRadius="8">
            <TextBlock TextWrapping="Wrap"
                       Foreground="#444"
                       Text="MVP Phase 5 mode: app tự chạy cùng Windows, chống tắt ở mức cơ bản, khóa/mở theo lệnh realtime từ billing server." />
        </Border>
    </Grid>
</Window>
