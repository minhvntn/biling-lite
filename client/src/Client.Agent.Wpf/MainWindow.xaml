<Window x:Class="Client.Agent.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Manager Client"
        Height="620"
        Width="280"
        MinWidth="260"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#E6E4DD">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#ECF5FF" />
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#8ABCF0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#D8EAFD" />
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#5A9ADF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7FAFC" />
            <Setter Property="BorderBrush" Value="#B8C0CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2E3138" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="AgentIdTextBlock"
                               Foreground="#F5F5F5"
                               FontWeight="SemiBold"
                               FontSize="13" />
                    <TextBlock Text="  " />
                    <Ellipse x:Name="ConnectionIndicator" Width="9" Height="9" Fill="#EF4444" Margin="2,0,4,0" />
                    <TextBlock x:Name="ConnectionStatusTextBlock"
                               Foreground="#D1D5DB"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Text="Mất kết nối" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#9CA3AF"
                           FontSize="12"
                           Text="Client" />
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12,10,12,12">
                <Border Background="#FEFFFC" BorderBrush="#C9D0D8" BorderThickness="1" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource MetricLabelStyle}" Text="Tổng thời gian:" Margin="0,0,8,8" />
                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Margin="0,0,0,8">
                            <TextBlock x:Name="TotalTimeValueTextBlock" Text="1000:00" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Border>

                        <TextBlock Grid.Row="1" Style="{StaticResource MetricLabelStyle}" Text="Thời gian sử dụng:" Margin="0,0,8,8" />
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Margin="0,0,0,8">
                            <TextBlock x:Name="UsedTimeValueTextBlock" Text="00:00" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Border>

                        <TextBlock Grid.Row="2" Style="{StaticResource MetricLabelStyle}" Text="Thời gian còn lại:" Margin="0,0,8,8" />
                        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Margin="0,0,0,8">
                            <TextBlock x:Name="RemainingTimeValueTextBlock" Text="1000:00" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Border>

                        <TextBlock Grid.Row="3" Style="{StaticResource MetricLabelStyle}" Text="Chi phí giờ chơi:" Margin="0,0,8,8" />
                        <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource MetricValueStyle}" Margin="0,0,0,8">
                            <TextBlock x:Name="GameCostValueTextBlock" Text="0" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Border>

                        <TextBlock Grid.Row="4" Style="{StaticResource MetricLabelStyle}" Text="Chi phí dịch vụ:" Margin="0,0,8,0" />
                        <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource MetricValueStyle}">
                            <TextBlock x:Name="ServiceCostValueTextBlock" Text="0" HorizontalAlignment="Right" FontFamily="Consolas" />
                        </Border>

                        <Border Grid.Row="5" Grid.ColumnSpan="2" Margin="0,10,0,0" Background="#F3F7FF" BorderBrush="#BCD2F0" BorderThickness="1" CornerRadius="4" Padding="6">
                            <TextBlock x:Name="MachineStateTextBlock"
                                       Text="Sẵn sàng"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <TextBlock x:Name="LastCommandTextBlock"
                           Margin="2,8,2,6"
                           Foreground="#6B7280"
                           FontSize="11"
                           Text="Lệnh gần nhất: Khởi động" />

                <WrapPanel HorizontalAlignment="Center" ItemWidth="78" ItemHeight="72" Margin="0,4,0,8">
                    <Button Style="{StaticResource ActionButtonStyle}" Click="MessagesButton_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="✉" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="Tin nhắn" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="ServicesButton_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="☕" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="Dịch vụ" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="LoyaltyButton_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="★" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="Điểm" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="TransferBalanceButton_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⇄" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="Chuyển tiền" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="LogoutButton_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⏻" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="Đăng xuất" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="PasswordButton_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🔑" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="Mật khẩu" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="LockButton_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🔒" FontSize="22" HorizontalAlignment="Center" />
                            <TextBlock Text="Khóa máy" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Border Height="108"
                        CornerRadius="5"
                        BorderBrush="#3768A8"
                        BorderThickness="1"
                        Padding="10"
                        Background="#0F3F7E">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ServerManagerBilling Client"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <TextBlock Text="• Kết nối máy chủ realtime"
                                   Foreground="#CFE5FF"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="• Khóa/Mở máy theo lệnh"
                                   Foreground="#CFE5FF" />
                        <TextBlock Text="• Theo dõi thời gian và chi phí"
                                   Foreground="#CFE5FF" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
