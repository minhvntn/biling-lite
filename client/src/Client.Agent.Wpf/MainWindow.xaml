<Window x:Class="Client.Agent.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Manager Client"
        Height="608"
        Width="256"
        MinWidth="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="#F3F4F6">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="72" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#F9FAFB" />
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#3B82F6" />
                                <Setter Property="Foreground" Value="#3B82F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#EFF6FF" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96" CenterX="35" CenterY="35" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <DockPanel.LayoutTransform>
            <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
        </DockPanel.LayoutTransform>
        <Border DockPanel.Dock="Top" Background="#111827" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10" Height="10" CornerRadius="5" Background="#10B981" x:Name="ConnectionIndicator" Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock x:Name="AgentIdTextBlock"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <TextBlock x:Name="ConnectionStatusTextBlock"
                                   Foreground="#9CA3AF"
                                   FontSize="13"
                                   Text="Connecting..." />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0" x:Name="UserInfoPanel" Visibility="Collapsed">
                    <TextBlock x:Name="MemberUsernameTextBlock" Foreground="White" FontSize="17" FontWeight="Bold" HorizontalAlignment="Right" />
                    <Border x:Name="MemberRankBorder"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="16"
                            Padding="8,4,8,4"
                            MinWidth="0"
                            Height="54"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0">
                        <Grid HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="MemberRankIconBadgeBorder"
                                    Width="48"
                                    Height="48"
                                    CornerRadius="24"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Image x:Name="MemberRankIconImage"
                                           Width="44"
                                           Height="44"
                                           Visibility="Collapsed"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                    <TextBlock x:Name="MemberRankIconTextBlock"
                                           Foreground="#CFE3FF"
                                           FontSize="18"
                                           FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="R" />
                                </Grid>
                            </Border>

                            <TextBlock x:Name="MemberRankTextBlock"
                                       Grid.Column="1"
                                       Foreground="#EAF3FF"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       Margin="6,0,0,0" />
                        </Grid>
                    </Border>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="–"
                        Width="30"
                        Height="24"
                        Foreground="#9CA3AF"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="22"
                        FontWeight="Bold"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="8,-2,-2,0"
                        Padding="0"
                        Click="MinimizeButton_Click"
                        Cursor="Hand" />
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,12">
                <Border Margin="0,0,0,8" Background="White" CornerRadius="12" Padding="12" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" Background="#DBEAFE" CornerRadius="20" HorizontalAlignment="Left">
                            <TextBlock x:Name="StatusIconTextBlock" Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusTitleTextBlock" Text="Trạng thái máy" FontSize="13" Foreground="#6B7280" />
                            <TextBlock x:Name="MachineStateTextBlock"
                                       Text="Đang sử dụng"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#1D4ED8" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock x:Name="TotalTimeLabelTextBlock" Style="{StaticResource MetricLabelStyle}" Text="Tổng thời gian" />
                            <TextBlock x:Name="TotalTimeValueTextBlock" Style="{StaticResource MetricValueStyle}" Text="100:00" />
                        </Grid>
                        <Rectangle Height="1" Fill="#F3F4F6" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,8">
                            <TextBlock x:Name="UsedTimeLabelTextBlock" Style="{StaticResource MetricLabelStyle}" Text="Đã sử dụng" />
                            <TextBlock x:Name="UsedTimeValueTextBlock" Style="{StaticResource MetricValueStyle}" Text="00:25" Foreground="#EF4444" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <TextBlock x:Name="RemainingTimeLabelTextBlock" Style="{StaticResource MetricLabelStyle}" Text="Còn lại" />
                            <TextBlock x:Name="RemainingTimeValueTextBlock" Style="{StaticResource MetricValueStyle}" Text="99:35" Foreground="#10B981" />
                        </Grid>
                        <Rectangle Height="1" Fill="#F3F4F6" Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,6">
                            <TextBlock x:Name="GameCostLabelTextBlock" Style="{StaticResource MetricLabelStyle}" Text="Tiền giờ chơi" />
                            <TextBlock x:Name="GameCostValueTextBlock" Style="{StaticResource MetricValueStyle}" Text="12,000" />
                        </Grid>
                        <Grid>
                            <TextBlock x:Name="ServiceCostLabelTextBlock" Style="{StaticResource MetricLabelStyle}" Text="Tiền dịch vụ" />
                            <TextBlock x:Name="ServiceCostValueTextBlock" Style="{StaticResource MetricValueStyle}" Text="0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="LastCommandTextBlock"
                           Margin="4,0,0,8"
                           Foreground="#9CA3AF"
                           FontSize="12"
                           Visibility="Collapsed"
                           Text="Lệnh gần nhất: Khởi động hệ thống" />

                <UniformGrid Columns="4" Margin="-4,0,-4,8">
                    <Button Style="{StaticResource ActionButtonStyle}" Click="MessagesButton_Click">
                        <StackPanel>
                            <TextBlock x:Name="MessagesIconTextBlock" Text="💬" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="MessagesLabelTextBlock" Text="Tin nhắn" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="ServicesButton_Click">
    <StackPanel>
        <Grid Width="34" Height="24" HorizontalAlignment="Center">
            <TextBlock x:Name="ServicesIconTextBlock"
                       Text="🛒"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <Border x:Name="ServicesBadgeBorder"
                    Visibility="Collapsed"
                    Background="#EF4444"
                    BorderBrush="White"
                    BorderThickness="1"
                    CornerRadius="9"
                    MinWidth="18"
                    Height="18"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-4,-8,0"
                    Padding="4,0">
                <TextBlock x:Name="ServicesBadgeTextBlock"
                           Text="0"
                           Foreground="White"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </Grid>
        <TextBlock x:Name="ServicesLabelTextBlock"
                   Text="Dịch vụ"
                   FontSize="12"
                   Margin="0,4,0,0"
                   HorizontalAlignment="Center"
                   Foreground="#374151" />
    </StackPanel>
</Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="LoyaltyButton_Click">
                        <StackPanel>
                            <TextBlock x:Name="LoyaltyIconTextBlock" Text="🎡" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="LoyaltyLabelTextBlock" Text="&#272;&#7893;i &#273;i&#7875;m" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="TransferBalanceButton_Click">
                        <StackPanel>
                            <TextBlock x:Name="TransferIconTextBlock" Text="💸" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="TransferLabelTextBlock" Text="Chuyển tiền" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="WithdrawActionButton" Style="{StaticResource ActionButtonStyle}" Click="WithdrawBalanceButton_Click">
                        <StackPanel>
                            <TextBlock x:Name="WithdrawIconTextBlock" Text="💵" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="WithdrawLabelTextBlock" Text="Rút tiền" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="TopupRequestActionButton" Style="{StaticResource ActionButtonStyle}" Click="TopupRequestButton_Click">
                        <StackPanel>
                            <TextBlock x:Name="TopupRequestIconTextBlock" Text="💳" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="TopupRequestLabelTextBlock" Text="Nạp tiền" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="PasswordButton_Click">
                        <StackPanel>
                            <TextBlock x:Name="PasswordIconTextBlock" Text="🔑" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="PasswordLabelTextBlock" Text="Đổi mật mã" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="LogoutActionButton" Style="{StaticResource ActionButtonStyle}" Click="LogoutButton_Click">
                        <StackPanel>
                            <TextBlock x:Name="LogoutIconTextBlock" Text="🚪" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="LogoutLabelTextBlock" Text="Đăng xuất" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#374151" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ActionButtonStyle}" Click="LockButton_Click" BorderBrush="#FECACA" Background="#FEF2F2">
                        <StackPanel>
                            <TextBlock x:Name="LockIconTextBlock" Text="🔒" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="LockLabelTextBlock" Text="Khóa máy" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="#DC2626" />
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <Border CornerRadius="12" Padding="16" BorderThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E40AF" Offset="0" />
                            <GradientStop Color="#1D4ED8" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="FooterTitleTextBlock" Text="Loyalty Program" Foreground="White" FontWeight="Bold" FontSize="16" />
                            <TextBlock x:Name="FooterDescriptionTextBlock"
                                       Text="Tích lũy điểm khi chơi để đổi giờ hoặc quay thưởng hấp dẫn!"
                                       Foreground="#BFDBFE"
                                       FontSize="13"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock x:Name="FooterIconTextBlock"
                                   Text="💎"
                                   FontSize="32"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Opacity="0.3"
                                   Margin="0,0,-8,0" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>

