<Window x:Class="Client.Agent.Wpf.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Machine Locked"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#101317"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="20">
            <TextBlock Text="MÁY TRẠM ĐANG KHÓA"
                       Foreground="#F3F4F6"
                       FontSize="42"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBlock Text="Vui lòng đăng nhập để bắt đầu sử dụng"
                       Foreground="#C7CBD3"
                       FontSize="18"
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <Border Margin="0,20,0,0"
                    Width="368"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Đăng nhập máy trạm"
                               Foreground="#0F172A"
                               FontWeight="SemiBold"
                               FontSize="20" />

                    <TextBlock Text="Tên đăng nhập" Margin="0,14,0,5" Foreground="#334155" FontWeight="SemiBold" FontSize="13" />
                    <TextBox x:Name="UsernameTextBox"
                             Height="32"
                             Padding="8,4"
                             FontSize="13"
                             KeyDown="Input_KeyDown" />

                    <TextBlock Text="Mật khẩu" Margin="0,10,0,5" Foreground="#334155" FontWeight="SemiBold" FontSize="13" />
                    <PasswordBox x:Name="PasswordBox"
                                 Height="32"
                                 Padding="8,4"
                                 FontSize="13"
                                 KeyDown="Input_KeyDown" />

                    <TextBlock x:Name="ErrorTextBlock"
                               Margin="0,8,0,0"
                               Foreground="#DC2626"
                               FontSize="12"
                               TextWrapping="Wrap" />

                    <Button x:Name="LoginButton"
                            Margin="0,14,0,0"
                            Height="34"
                            Content="Đăng nhập"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Background="#2563EB"
                            Foreground="White"
                            Click="LoginButton_Click" />

                    <Button x:Name="GuestLoginButton"
                            Margin="0,6,0,0"
                            Height="34"
                            Content="Sử dụng Khách vãng lai"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Background="Transparent"
                            BorderBrush="#2563EB"
                            BorderThickness="1"
                            Foreground="#2563EB"
                            Click="GuestLoginButton_Click" />

                    <TextBlock Text="Bạn có thể dùng tài khoản hội viên đã tạo để đăng nhập."
                               Margin="0,10,0,0"
                               Foreground="#64748B"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
