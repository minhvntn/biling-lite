<Window x:Class="Client.Agent.Wpf.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Machine Locked"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#101317"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="24">
            <TextBlock Text="MÁY TRẠM ĐANG KHÓA"
                       Foreground="#F3F4F6"
                       FontSize="52"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBlock Text="Vui lòng đăng nhập để bắt đầu sử dụng"
                       Foreground="#C7CBD3"
                       FontSize="22"
                       Margin="0,14,0,0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <Border Margin="0,24,0,0"
                    Width="460"
                    Background="#F8FAFC"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="22">
                <StackPanel>
                    <TextBlock Text="Đăng nhập máy trạm"
                               Foreground="#0F172A"
                               FontWeight="SemiBold"
                               FontSize="24" />

                    <TextBlock Text="Tên đăng nhập" Margin="0,18,0,6" Foreground="#334155" FontWeight="SemiBold" />
                    <TextBox x:Name="UsernameTextBox"
                             Height="38"
                             Padding="10,6"
                             FontSize="15"
                             KeyDown="Input_KeyDown" />

                    <TextBlock Text="Mật khẩu" Margin="0,12,0,6" Foreground="#334155" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox"
                                 Height="38"
                                 Padding="10,6"
                                 FontSize="15"
                                 KeyDown="Input_KeyDown" />

                    <TextBlock x:Name="ErrorTextBlock"
                               Margin="0,10,0,0"
                               Foreground="#DC2626"
                               FontSize="13"
                               TextWrapping="Wrap" />

                    <Button x:Name="LoginButton"
                            Margin="0,18,0,0"
                            Height="42"
                            Content="Đăng nhập"
                            FontWeight="SemiBold"
                            FontSize="15"
                            Background="#2563EB"
                            Foreground="White"
                            Click="LoginButton_Click" />

                    <TextBlock Text="Bạn có thể dùng tài khoản hội viên đã tạo để đăng nhập."
                               Margin="0,12,0,0"
                               Foreground="#64748B"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
