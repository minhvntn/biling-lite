<Window x:Class="Server.Admin.App.ChangeAdminCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi tài khoản Admin" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F9FAFB">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Đổi tài khoản Admin" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="Username mới" Margin="0,0,0,5" Foreground="#4B5563"/>
            <TextBox x:Name="UsernameTextBox" Height="32" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,12"/>
            
            <TextBlock Text="Mật khẩu mới" Margin="0,0,0,5" Foreground="#4B5563"/>
            <PasswordBox x:Name="PasswordBox" Height="32" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,20"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" Width="80" Height="32" Margin="0,0,10,0" Click="CancelButton_Click" Background="White"/>
                <Button x:Name="SaveButton" Content="Lưu thay đổi" Width="100" Height="32" Background="#3B82F6" Foreground="White" FontWeight="Bold" Click="SaveButton_Click"/>
            </StackPanel>
            
            <TextBlock x:Name="StatusTextBlock" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
