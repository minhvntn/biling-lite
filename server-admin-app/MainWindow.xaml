                                      Checked="WebFilterEnabledCheckBox_Checked"
                                      Unchecked="WebFilterEnabledCheckBox_Unchecked" />
                        </StackPanel>

                        <TextBlock x:Name="WebFilterStatusTextBlock"
                                   Grid.Row="1"
