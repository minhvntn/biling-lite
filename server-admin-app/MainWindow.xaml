                                   Margin="0,6,0,0"
                                   Foreground="#555"
                                   Text="Đang tải cài đặt điểm tích lũy..." />

                        <StackPanel Grid.Row="11" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Padding="12,6" Margin="0,0,8,0" Click="SaveFontSizeButton_Click" Content="Lưu cài đặt" />
                            <Button Padding="12,6" Click="ResetFontSizeButton_Click" Content="Đặt lại mặc định" />
