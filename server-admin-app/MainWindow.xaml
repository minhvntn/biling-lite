                                    Minimum="6"
                                    Maximum="24"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="MachineContextMenuPaddingSlider_ValueChanged" />
                            <TextBlock x:Name="MachineContextMenuPaddingValueTextBlock" Margin="10,0,0,0" VerticalAlignment="Center" Text="12" />
                        </StackPanel>

                        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock VerticalAlignment="Center" Text="Cỡ chữ menu chuột phải bảng Máy trạm:" Margin="0,0,8,0" />
                            <Slider x:Name="MachineContextMenuFontSizeSlider"
                                    Width="180"
                                    Minimum="10"
                                    Maximum="30"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="MachineContextMenuFontSizeSlider_ValueChanged" />
