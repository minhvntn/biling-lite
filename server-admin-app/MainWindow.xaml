                                    Margin="0,0,8,0"
                                    Click="ReloadWebFilterSettingsButton_Click"
                                    Content="Tải lại" />
                            <Button Padding="12,6"
                                    Click="SaveWebFilterSettingsButton_Click"
                                    Content="Lưu áp dụng" />
                        </StackPanel>

                        <TextBlock Grid.Row="5"
                                   Margin="0,10,0,0"
                                   Foreground="#555"
                                   Text="G\u1ee3i \u00fd: nh\u1eadp d\u1ea1ng domain ch\u00ednh, v\u00ed d\u1ee5: badsite.com (kh\u00f4ng c\u1ea7n http://)." />
                    </Grid>
