                                            <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="270" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#334155" Text="Thư mục lưu backup:" />
                                                <TextBox x:Name="AutoBackupDirectoryTextBox"
                                                         Grid.Column="1"
                                                         Height="30"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="AutoBackupConfigTextChanged" />
                                            </Grid>

                                            <Grid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="270" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#334155" Text="Giữ file backup (ngày):" />
                                                <TextBox x:Name="AutoBackupRetentionDaysTextBox"
                                                         Grid.Column="1"
                                                         Width="110"
                                                         Height="30"
                                                         HorizontalAlignment="Left"
                                                         VerticalContentAlignment="Center"
                                                         Text="30"
                                                         TextChanged="AutoBackupConfigTextChanged" />
                                            </Grid>

                                            <StackPanel Grid.Row="6"
                                                        Grid.ColumnSpan="2"
                                                        Orientation="Horizontal"
                                                        Margin="0,12,0,0">
                                                <Button Padding="14,7"
                                                        Margin="0,0,8,0"
                                                        Content="Lưu lịch backup"
                                                        Click="SaveBackupSettingsButton_Click" />
                                                <Button x:Name="RunBackupNowButton"
                                                        Padding="14,7"
                                                        Margin="0,0,8,0"
                                                        Content="Backup ngay"
                                                        Click="RunBackupNowButton_Click" />
                                                <Button x:Name="ImportBackupFileButton"
                                                        Padding="14,7"
                                                        Content="Import backup..."
                                                        Click="ImportBackupFileButton_Click" />
                                            </StackPanel>

                                            <TextBlock x:Name="AutoBackupStatusTextBlock"
                                                       Grid.Row="7"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,8,0,0"
                                                       Foreground="#64748B"
                                                       Text="Đang tải cài đặt backup..." />
                                            <TextBlock x:Name="AutoBackupLastRunTextBlock"
                                                       Grid.Row="8"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,8,0,0"
                                                       Foreground="#64748B"
                                                       Text="Lần backup gần nhất: -" />
                                        </Grid>
                                    </Border>
                                </TabItem>
                            </TabControl>

                            <StackPanel Grid.Row="4">
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Button Padding="14,7" Margin="0,0,8,0" Click="SaveFontSizeButton_Click" Content="Lưu cài đặt" />
                                    <Button Padding="14,7" Click="ResetFontSizeButton_Click" Content="Đặt lại mặc định" />
                                </StackPanel>

                                <TextBlock Margin="0,10,0,0"
                                           Foreground="#64748B"
                                           Text="Thông tin: Cỡ chữ được xem trước ngay khi kéo thanh trượt." />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
                <TabItem x:Name="AdminTab">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F510;" Margin="0,0,6,0" />
                            <TextBlock Text="Admin" />
                        </StackPanel>
                    </TabItem.Header>
                    <TabControl Margin="8">
                        <TabItem Header="Server">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Danh sách tài khoản Server Admin" DockPanel.Dock="Left" />
                                        <Button Content="Đổi tài khoản ADMIN mặc định" DockPanel.Dock="Right" Padding="10,4" Click="ChangeAdminCredentialsButton_Click" Background="#F3F4F6"/>
                                    </DockPanel>
                                    <TextBlock Margin="0,6,0,0" Foreground="#666" Text="Bạn có thể tạo thêm tài khoản nhân viên. Tài khoản ADMIN không thể bị xóa." />
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Tên đăng nhập" FontSize="11" Foreground="#666" Margin="0,0,0,2"/>
                                            <TextBox x:Name="NewStaffUsernameTextBox" Width="180" Height="30" Padding="5,0" VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Mật khẩu" FontSize="11" Foreground="#666" Margin="0,0,0,2"/>
                                            <PasswordBox x:Name="NewStaffPasswordBox" Width="180" Height="30" Padding="5,0" VerticalContentAlignment="Center" />
                                        </StackPanel>
                                        <Button Content="Tạo tài khoản STAFF" Width="140" Height="30" Click="CreateStaffButton_Click" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock x:Name="StaffActionStatusTextBlock" Margin="0,8,0,0" Foreground="#555" />
                                </StackPanel>
                                <DataGrid x:Name="ServerUsersDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding Username}" Width="200" />
                                        <DataGridTextColumn Header="Quyền" Binding="{Binding Role}" Width="120" />
                                        <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="180" />
                                        <DataGridTemplateColumn Header="Hành động" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Xóa" Click="DeleteStaffButton_Click" Tag="{Binding Id}" Margin="4,2"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Client">
                            <Grid Margin="12">
                                <StackPanel>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Tài khoản đăng nhập Admin máy trạm" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#666"
                                               Text="Bấm nút bên dưới để mở popup đổi username/mật khẩu." />
                                    <Button Margin="0,14,0,0"
                                            Width="240"
                                            Padding="12,6"
                                            HorizontalAlignment="Left"
                                            Content="Đổi tài khoản admin..."
                                            Click="OpenAdminCredentialPopupButton_Click" />
                                    <TextBlock x:Name="AdminCredentialStatusTextBlock"
                                               Margin="0,10,0,0"
                                               Foreground="#555"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>
            </TabControl>
        </DockPanel>

        <Grid x:Name="MemberModalOverlay" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Width="460" Height="420" Background="White" BorderBrush="#CFCFCF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Thêm hội viên" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="1" Text="Tên đăng nhập" Margin="0,0,0,4" />
                    <TextBox x:Name="MemberUsernameTextBox" Grid.Row="2" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="3" Text="Mật khẩu" Margin="0,0,0,4" />
                    <PasswordBox x:Name="MemberPasswordBox" Grid.Row="4" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="5" Text="Số điện thoại (không bắt buộc)" Margin="0,0,0,4" />
                    <TextBox x:Name="MemberPhoneTextBox" Grid.Row="6" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="7" Text="CCCD/CMND (không bắt buộc)" Margin="0,0,0,4" />
                    <TextBox x:Name="MemberIdentityTextBox" Grid.Row="8" Height="32" VerticalContentAlignment="Center" />

                    <TextBlock x:Name="MemberModalErrorTextBlock" Grid.Row="9" VerticalAlignment="Top" Foreground="#B42318" Margin="0,8,0,0" TextWrapping="Wrap" />

                    <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Padding="10,5" Margin="0,0,8,0" Click="CreateMemberConfirmButton_Click" Content="Tạo" />
                        <Button Padding="10,5" Click="CancelMemberModalButton_Click" Content="Hủy" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="TopupModalOverlay" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="120">
            <Border Width="520"
                    MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
                    Margin="0,16"
                    Background="White"
                    BorderBrush="#CFCFCF"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TopupModalTitleTextBlock"
                               Grid.Row="0"
                               Text="Nạp tiền hội viên"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock x:Name="TopupModalMemberTextBlock"
                                   Text="Chọn số tiền nạp:"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="TopupModalCurrentBalanceTextBlock"
                                   Margin="0,4,0,0"
                                   Foreground="#334155"
                                   Text="Số dư hiện tại: - VND" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="#E7F3FF"
                            BorderBrush="#97B8E2"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,8">
                        <TextBlock x:Name="TopupModalAmountTextBlock"
                                   Text="0 VND"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="#09248C"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="Bấm nhiều lần để cộng dồn. Không giới hạn trần mỗi lần nạp."
                               Foreground="DimGray"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="TopupModeAddButton"
                                Content="Nạp (+)"
                                Width="110"
                                Height="34"
                                Margin="0,0,8,0"
                                FontWeight="SemiBold"
                                Click="TopupModeAddButton_Click" />
                        <Button x:Name="TopupModeSubtractButton"
                                Content="Trừ (-)"
                                Width="110"
                                Height="34"
                                FontWeight="SemiBold"
                                Click="TopupModeSubtractButton_Click" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,0,0,10">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="Nhập số tiền:" />
                            <TextBox x:Name="TopupCustomAmountTextBox"
                                     Grid.Column="1"
                                     Height="32"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,8,0"
                                     TextChanged="TopupCustomAmountTextBox_TextChanged"
                                     KeyDown="TopupCustomAmountTextBox_KeyDown" />
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Text="Nhập số phút:" />
                            <TextBox x:Name="TopupMinutesTextBox"
                                     Grid.Column="1"
                                     Height="32"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,8,0"
                                     TextChanged="TopupMinutesTextBox_TextChanged"
                                     KeyDown="TopupMinutesTextBox_KeyDown" />
                        </Grid>

                        <TextBlock x:Name="TopupMinutesRateHintTextBlock"
                                   Foreground="#64748B"
                                   FontSize="12"
                                   Text="Đơn giá quy đổi: -"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Margin="0,0,0,10">
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Button Content="1,000" Tag="1000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="2,000" Tag="2000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="3,000" Tag="3000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="4,000" Tag="4000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="5,000" Tag="5000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="6,000" Tag="6000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="7,000" Tag="7000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="8,000" Tag="8000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="9,000" Tag="9000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                        </UniformGrid>

                        <UniformGrid Columns="3">
                            <Button Content="10,000" Tag="10000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="20,000" Tag="20000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="30,000" Tag="30000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="40,000" Tag="40000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="50,000" Tag="50000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="60,000" Tag="60000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="70,000" Tag="70000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="80,000" Tag="80000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="90,000" Tag="90000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                        </UniformGrid>
                    </StackPanel>

                    <TextBlock x:Name="TopupModalErrorTextBlock"
                               Grid.Row="7"
                               Foreground="#B42318"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="TopupUndoButton"
                                Content="-"
                                Width="68"
                                Height="36"
                                Margin="0,0,8,0"
                                FontWeight="Bold"
                                Click="TopupUndoButton_Click" />
                        <Button x:Name="TopupClearButton"
                                Content="Xóa"
                                Width="90"
                                Height="36"
                                Margin="0,0,8,0"
                                FontWeight="SemiBold"
                                Click="TopupClearButton_Click" />
                        <Button Content="Hủy"
                                Width="90"
                                Height="36"
                                Margin="0,0,8,0"
                                Click="TopupCancelButton_Click" />
                        <Button x:Name="TopupSubmitButton"
                                Content="Nạp"
                                Width="90"
                                Height="36"
                                FontWeight="SemiBold"
                                Background="#79C959"
                                BorderBrush="#3F8A2E"
                                Click="TopupSubmitButton_Click" />
                    </StackPanel>
                </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border x:Name="GuestLoginToastBorder"
                Panel.ZIndex="4000"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,18,18,0"
                MaxWidth="360"
                Padding="12,10"
                CornerRadius="10"
                BorderThickness="1"
                BorderBrush="#1D4ED8"
                Background="#EFF6FF">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Text="Thong bao may tram"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1D4ED8" />
                    <Button DockPanel.Dock="Right"
                            Content="Đóng"
                            Padding="8,2"
                            FontSize="12"
                            Margin="10,0,0,0"
                            Click="GuestLoginToastCloseButton_Click" />
                </DockPanel>
                <TextBlock x:Name="GuestLoginToastMessageTextBlock"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Foreground="#0F172A"
                           Text="Máy trạm vừa có khách đăng nhập." />
            </StackPanel>
        </Border>
    </Grid>
</Window>



