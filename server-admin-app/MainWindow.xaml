<Window x:Class="Server.Admin.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Server Manager Admin"
        Height="900"
        Width="1550"
        MinHeight="720"
        MinWidth="1240"
        PreviewMouseDown="Window_PreviewMouseDown"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1E5AA8" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#CFCFCF" />
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#E6E6E6" />
        <Thickness x:Key="MachineContextMenuItemPadding">12</Thickness>
        <sys:Double x:Key="MachineContextMenuFontSize">14</sys:Double>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F2F2F2" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E5AA8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="8" />
        </Style>
    </Window.Resources>

    <Grid>
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="#1B4C86" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="Server Manager Billing [ADMIN]" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="HealthIndicator" Width="12" Height="12" Fill="#9ca3af" Margin="0,0,6,0" />
                        <TextBlock x:Name="HealthTextBlock" Foreground="White" Text="Backend: đang kiểm tra" />
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabControl" Margin="8" SelectionChanged="MainTabControl_SelectionChanged">
                <TabItem Header="Máy trạm">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Margin="0,0,6,0" Padding="10,5" Click="RefreshMachinesButton_Click" Content="Làm mới" />
                            <Button Grid.Column="1" Margin="0,0,6,0" Padding="10,5" Click="OpenMachineButton_Click" Content="Mở máy" />
                            <Button Grid.Column="2" Margin="0,0,6,0" Padding="10,5" Click="LockMachineButton_Click" Content="Khóa máy" />
                            <Button Grid.Column="3" Margin="0,0,6,0" Padding="10,5" Click="UnlockAllFilterButton_Click" Content="Bỏ lọc" />

                            <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="0,0,6,0" Text="Trạng thái:" />
                            <ComboBox x:Name="StatusFilterComboBox"
                                      Grid.Column="6"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="StatusFilterComboBox_SelectionChanged">
                                <ComboBoxItem Content="Tất cả" IsSelected="True" />
                                <ComboBoxItem Content="Đang sử dụng" />
                                <ComboBoxItem Content="Đang tắt" />
                                <ComboBoxItem Content="Sẵn sàng" />
                                <ComboBoxItem Content="Offline" />
                            </ComboBox>

                            <TextBlock Grid.Column="8" VerticalAlignment="Center" Margin="0,0,6,0" Text="Tìm máy:" />
                            <TextBox x:Name="SearchTextBox" Grid.Column="9" VerticalContentAlignment="Center" TextChanged="SearchTextBox_TextChanged" />

                            <TextBlock Grid.Column="11" VerticalAlignment="Center" x:Name="LastSyncTextBlock" Text="Đồng bộ: -" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,8,0" Padding="10,6" Background="#EEF2FF" CornerRadius="8">
                                <TextBlock x:Name="SummaryTotalTextBlock" FontWeight="SemiBold" Text="Tổng máy: 0" />
                            </Border>
                            <Border Grid.Column="1" Margin="0,0,8,0" Padding="10,6" Background="#ECFDF3" CornerRadius="8">
                                <TextBlock x:Name="SummaryUsingTextBlock" FontWeight="SemiBold" Text="Đang sử dụng: 0" />
                            </Border>
                            <Border Grid.Column="2" Margin="0,0,8,0" Padding="10,6" Background="#FEF2F2" CornerRadius="8">
                                <TextBlock x:Name="SummaryLockedTextBlock" FontWeight="SemiBold" Text="Đang tắt: 0" />
                            </Border>
                            <Border Grid.Column="3" Padding="10,6" Background="#FFF7ED" CornerRadius="8">
                                <TextBlock x:Name="SummaryMoneyTextBlock" FontWeight="SemiBold" Text="Tiền tạm tính: 0" />
                            </Border>
                        </Grid>

                        <DataGrid x:Name="MachinesDataGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternationCount="2"
                                  ColumnWidth="*"
                                  ContextMenuOpening="MachinesDataGrid_ContextMenuOpening"
                                  MouseDoubleClick="MachinesDataGrid_MouseDoubleClick"
                                  SelectionChanged="MachinesDataGrid_SelectionChanged">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="MachinesDataGridRow_PreviewMouseRightButtonDown" />
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu FontSize="{DynamicResource MachineContextMenuFontSize}">
                                    <ContextMenu.Resources>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Padding" Value="{DynamicResource MachineContextMenuItemPadding}" />
                                        </Style>
                                    </ContextMenu.Resources>
                                    <MenuItem x:Name="ContextOpenMachineMenuItem" Header="Mở máy" Click="ContextOpenMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextOpenGuestMachineMenuItem" Header="Mở máy khách vãng lai..." Click="ContextOpenGuestMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextLockMachineMenuItem" Header="Khóa máy" Click="ContextLockMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextTopupMachineMemberMenuItem" Header="Nạp tiền hội viên đang dùng máy..." Click="ContextTopupMachineMemberMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextRestartMachineMenuItem" Header="Khởi động lại máy trạm" Click="ContextRestartMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextShutdownMachineMenuItem" Header="Tắt máy trạm">
                                        <MenuItem x:Name="ContextShutdownSelectedMachineMenuItem"
                                                  Header="Tắt máy đã chọn"
                                                  Click="ContextShutdownSelectedMachineMenuItem_Click" />
                                        <MenuItem x:Name="ContextShutdownReadyMachinesMenuItem"
                                                  Header="Tắt các máy sẵn sàng"
                                                  Click="ContextShutdownReadyMachinesMenuItem_Click" />
                                    </MenuItem>
                                    <MenuItem x:Name="ContextControlMachineMenuItem" Header="Điều khiển máy trạm">
                                        <MenuItem x:Name="ContextControlCloseAppsMenuItem"
                                                  Header="Đóng tất cả ứng dụng"
                                                  Click="ContextCloseAppsMenuItem_Click" />
                                        <MenuItem x:Name="ContextControlRemoteMenuItem"
                                                  Header="Điều khiển từ xa (RDP)"
                                                  Click="ContextRemoteControlMachineMenuItem_Click" />
                                        <MenuItem x:Name="ContextControlScreenshotMenuItem"
                                                  Header="Chụp màn hình máy trạm"
                                                  Click="ContextCaptureScreenshotMachineMenuItem_Click" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem x:Name="ContextPauseMachineMenuItem" Header="Tạm nghỉ máy trạm" Click="ContextPauseMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextResumeMachineMenuItem" Header="Tiếp tục sử dụng" Click="ContextResumeMachineMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextTransferMachineMenuItem" Header="Chuyển máy" Click="ContextTransferMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextAssignGroupMenuItem" Header="Chuyển nhóm máy">
                                        <MenuItem Header="Đang tải nhóm máy..." IsEnabled="False" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem x:Name="ContextViewMachineBillingMenuItem" Header="Xem thanh toán..." Click="ContextViewMachineBillingMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextSelectServiceMenuItem" Header="Chọn dịch vụ..." Click="ContextSelectServiceMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextNotifyMachineMenuItem" Header="Gửi thông báo" Click="ContextNotifyMachineMenuItem_Click" />
                                    <Separator />
                                    <MenuItem Header="Làm mới danh sách" Click="ContextRefreshMachinesMenuItem_Click" />
                                    <MenuItem Header="Bỏ lọc tìm kiếm" Click="ContextClearMachineFiltersMenuItem_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Tên" Width="1.5*" MinWidth="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="10" Height="10" 
                                                         Fill="{Binding StatusIconBrush}" 
                                                         Margin="4,0,8,0" 
                                                         ToolTip="{Binding StatusIconToolTip}" />
                                                <TextBlock Text="{Binding Name}" 
                                                           VerticalAlignment="Center" 
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Tình trạng" Width="1.1*" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusBrush}"
                                                       FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Người sử dụng" Binding="{Binding UserName}" Width="1.1*" MinWidth="120" />
                                <DataGridTextColumn Header="Bắt đầu" Binding="{Binding StartedAtText}" Width="0.95*" MinWidth="100" />
                                <DataGridTextColumn Header="Đã sử dụng" Binding="{Binding UsedText}" Width="0.95*" MinWidth="100" />
                                <DataGridTextColumn Header="Còn lại" Binding="{Binding RemainingText}" Width="0.95*" MinWidth="100" />
                                <DataGridTextColumn Header="Tiền" Binding="{Binding MoneyText}" Width="0.8*" MinWidth="80" />
                                <DataGridTextColumn Header="Ngày" Binding="{Binding DateText}" Width="0.95*" MinWidth="95" />
                                <DataGridTextColumn Header="Phiên bản" Binding="{Binding VersionText}" Width="0.85*" MinWidth="90" />
                                <DataGridTextColumn Header="Nhóm" Binding="{Binding GroupName}" Width="1*" MinWidth="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="3" Margin="0,8,0,0" x:Name="SelectionTextBlock" Text="Chưa chọn máy" />
                    </Grid>
                </TabItem>

                <TabItem Header="Tài khoản">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="220" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Margin="0,0,8,0" Padding="10,5" Click="RefreshMembersButton_Click" Content="Làm mới" />
                            <Button Grid.Column="1" Margin="0,0,8,0" Padding="10,5" Click="AddMemberButton_Click" Content="Thêm hội viên" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBox x:Name="TopupAmountTextBox" Width="100" VerticalContentAlignment="Center" Text="0" />
                                <TextBox x:Name="BuyHoursTextBox" Width="80" Margin="6,0,0,0" VerticalContentAlignment="Center" Text="2" />
                                <TextBox x:Name="RatePerHourTextBox" Width="100" Margin="6,0,0,0" VerticalContentAlignment="Center" Text="15000" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,6,0" Text="Tìm:" />
                            <TextBox x:Name="MembersSearchTextBox" Grid.Column="3" VerticalContentAlignment="Center" TextChanged="MembersSearchTextBox_TextChanged" />

                            <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="8,0,0,0" x:Name="MembersLastSyncTextBlock" Text="Đồng bộ: -" />
                        </Grid>

                        <DataGrid x:Name="MembersDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternationCount="2"
                                  ContextMenuOpening="MembersDataGrid_ContextMenuOpening"
                                  MouseDoubleClick="MembersDataGrid_MouseDoubleClick"
                                  SelectionChanged="MembersDataGrid_SelectionChanged">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="MembersDataGridRow_PreviewMouseRightButtonDown" />
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Xem / sửa hội viên..." Click="ContextEditMemberMenuItem_Click" />
                                    <Separator />
                                    <MenuItem Header="Nạp tiền" Click="ContextTopupMemberMenuItem_Click" />
                                    <MenuItem Header="Mua giờ" Click="ContextBuyHoursMenuItem_Click" />
                                    <MenuItem Header="Chuyển tiền cho hội viên..." Click="ContextTransferMemberMenuItem_Click" />
                                    <Separator />
                                    <MenuItem Header="Tiền trả lại" Click="ContextRefundMemberMenuItem_Click" />
                                    <MenuItem Header="Tặng tiền miễn phí" Click="ContextGiftMemberMenuItem_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="130" />
                                <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="160" />
                                <DataGridTextColumn Header="Bậc VIP" Binding="{Binding Rank}" Width="100" />
                                <DataGridTextColumn Header="Tổng nạp" Binding="{Binding TotalTopupText}" Width="110" />
                                <DataGridTextColumn Header="Điểm" Binding="{Binding AvailablePoints}" Width="80" />
                                <DataGridTextColumn Header="SDT" Binding="{Binding Phone}" Width="120" />
                                <DataGridTextColumn Header="CCCD/CMND" Binding="{Binding IdentityNumber}" Width="140" />
                                <DataGridTextColumn Header="Số dư" Binding="{Binding BalanceText}" Width="120" />
                                <DataGridTextColumn Header="Giờ chơi" Binding="{Binding PlayHoursText}" Width="110" />
                                <DataGridTextColumn Header="Mật khẩu" Binding="{Binding PasswordState}" Width="100" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding ActiveText}" Width="100" />
                                <DataGridTextColumn Header="Tạo lúc" Binding="{Binding CreatedAtText}" Width="160" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="MemberTransactionsDataGrid"
                                  Grid.Row="2"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternationCount="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedAtText}" Width="170" />
                                <DataGridTextColumn Header="Loại" Binding="{Binding TypeText}" Width="120" />
                                <DataGridTextColumn Header="Tiền thay đổi" Binding="{Binding AmountDeltaText}" Width="140" />
                                <DataGridTextColumn Header="Giờ thay đổi" Binding="{Binding PlayHoursDeltaText}" Width="120" />
                                <DataGridTextColumn Header="Người tạo" Binding="{Binding CreatedBy}" Width="120" />
                                <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="3" Margin="0,8,0,0" x:Name="SelectedMemberTextBlock" Text="Chưa chọn hội viên" />
                    </Grid>
                </TabItem>

                <TabItem Header="Nhật ký hệ thống">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Padding="10,5" Click="RefreshSystemLogsButton_Click" Content="Làm mới" Margin="0,0,8,0" />
                            <TextBlock VerticalAlignment="Center" Text="Số dòng:" Margin="0,0,6,0" />
                            <ComboBox x:Name="SystemLogLimitComboBox" Width="110" SelectionChanged="SystemLogLimitComboBox_SelectionChanged">
                                <ComboBoxItem Content="50" />
                                <ComboBoxItem Content="100" IsSelected="True" />
                                <ComboBoxItem Content="200" />
                                <ComboBoxItem Content="500" />
                            </ComboBox>
                        </StackPanel>

                        <DataGrid x:Name="SystemLogsDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternationCount="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedAtText}" Width="170" />
                                <DataGridTextColumn Header="Nguồn" Binding="{Binding Source}" Width="90" />
                                <DataGridTextColumn Header="Sự kiện" Binding="{Binding EventType}" Width="230" />
                                <DataGridTextColumn Header="Máy" Binding="{Binding PcText}" Width="180" />
                                <DataGridTextColumn Header="Chi tiết" Binding="{Binding PayloadText}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Margin="0,8,0,0" x:Name="SystemLogInfoTextBlock" Text="Chưa tải log" />
                    </Grid>
                </TabItem>

                <TabItem Header="Nhật ký giao dịch">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Padding="10,5" Click="RefreshTransactionLogsButton_Click" Content="Xem báo cáo" Margin="0,0,8,0" />
                            <TextBlock VerticalAlignment="Center" Text="Kỳ:" Margin="0,0,6,0" />
                            <ComboBox x:Name="RevenuePeriodComboBox"
                                      Width="120"
                                      Margin="0,0,8,0"
                                      SelectionChanged="RevenuePeriodComboBox_SelectionChanged">
                                <ComboBoxItem Content="Ngày" Tag="day" IsSelected="True" />
                                <ComboBoxItem Content="Tuần" Tag="week" />
                                <ComboBoxItem Content="Tháng" Tag="month" />
                            </ComboBox>
                            <TextBlock VerticalAlignment="Center" Text="Ngày mốc:" Margin="0,0,6,0" />
                            <DatePicker x:Name="RevenueAnchorDatePicker"
                                        Width="140"
                                        Margin="0,0,8,0"
                                        SelectedDateChanged="RevenueAnchorDatePicker_SelectedDateChanged" />
                            <TextBlock x:Name="TransactionSummaryTextBlock" VerticalAlignment="Center" Text="Tổng doanh thu: 0" />
                        </StackPanel>

                        <DataGrid x:Name="SessionLogsDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternationCount="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Máy" Binding="{Binding PcName}" Width="120" />
                                <DataGridTextColumn Header="Agent" Binding="{Binding AgentId}" Width="130" />
                                <DataGridTextColumn Header="Bắt đầu" Binding="{Binding StartedAtText}" Width="160" />
                                <DataGridTextColumn Header="Kết thúc" Binding="{Binding EndedAtText}" Width="160" />
                                <DataGridTextColumn Header="Số phút" Binding="{Binding BillableMinutesText}" Width="90" />
                                <DataGridTextColumn Header="Tiền" Binding="{Binding AmountText}" Width="110" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="90" />
                                <DataGridTextColumn Header="Lý do" Binding="{Binding ClosedReason}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Margin="0,8,0,0" x:Name="TransactionsInfoTextBlock" Text="Chưa tải giao dịch" />
                    </Grid>
                </TabItem>

                <TabItem Header="Nhật ký website">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox x:Name="WebsiteLogsEnabledCheckBox"
                                      Grid.Column="0"
                                      Content="Bật ghi nhật ký website từ máy trạm"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      Checked="WebsiteLogsEnabledCheckBox_Checked"
                                      Unchecked="WebsiteLogsEnabledCheckBox_Unchecked" />
                            <Button Grid.Column="1"
                                    Padding="10,5"
                                    Margin="0,0,8,0"
                                    Click="SaveWebsiteLogSettingsButton_Click"
                                    Content="Lưu áp dụng" />
                            <Button Grid.Column="2"
                                    Padding="10,5"
                                    Click="ReloadWebsiteLogSettingsButton_Click"
                                    Content="Tải lại" />
                            <TextBlock x:Name="WebsiteLogsStatusTextBlock"
                                       Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="#555"
                                       Text="Đang tải cài đặt..." />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="230" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="100" />
