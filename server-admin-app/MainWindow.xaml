                        <TextBlock Grid.Row="12" Margin="0,12,0,0" Foreground="#555" Text="Thông tin: Cỡ chữ được xem trước ngay khi kéo thanh trượt." />
                    </Grid>
                </TabItem>
                <TabItem Header="Tài khoản Admin">
                    <Grid Margin="8">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Tài khoản đăng nhập Admin máy trạm" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#666"
                                       Text="Bấm nút bên dưới để mở popup đổi username/mật khẩu." />
                            <Button Margin="0,14,0,0"
                                    Width="240"
                                    Padding="12,6"
                                    HorizontalAlignment="Left"
                                    Content="Đổi tài khoản admin..."
                                    Click="OpenAdminCredentialPopupButton_Click" />
                            <TextBlock x:Name="AdminCredentialStatusTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="#555"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </DockPanel>

        <Grid x:Name="MemberModalOverlay" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Width="460" Height="420" Background="White" BorderBrush="#CFCFCF" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Thêm hội viên" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="1" Text="Tên đăng nhập" Margin="0,0,0,4" />
                    <TextBox x:Name="MemberUsernameTextBox" Grid.Row="2" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="3" Text="Mật khẩu" Margin="0,0,0,4" />
                    <PasswordBox x:Name="MemberPasswordBox" Grid.Row="4" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="5" Text="Số điện thoại (không bắt buộc)" Margin="0,0,0,4" />
                    <TextBox x:Name="MemberPhoneTextBox" Grid.Row="6" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,10" />

                    <TextBlock Grid.Row="7" Text="CCCD/CMND (không bắt buộc)" Margin="0,0,0,4" />
                    <TextBox x:Name="MemberIdentityTextBox" Grid.Row="8" Height="32" VerticalContentAlignment="Center" />

                    <TextBlock x:Name="MemberModalErrorTextBlock" Grid.Row="9" VerticalAlignment="Top" Foreground="#B42318" Margin="0,8,0,0" TextWrapping="Wrap" />

                    <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Padding="10,5" Margin="0,0,8,0" Click="CreateMemberConfirmButton_Click" Content="Tạo" />
                        <Button Padding="10,5" Click="CancelMemberModalButton_Click" Content="Hủy" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="TopupModalOverlay" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="120">
            <Border Width="520"
                    MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
                    Margin="0,16"
                    Background="White"
                    BorderBrush="#CFCFCF"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TopupModalTitleTextBlock"
                               Grid.Row="0"
                               Text="Nạp tiền hội viên"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock x:Name="TopupModalMemberTextBlock"
                                   Text="Chọn số tiền nạp:"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="TopupModalCurrentBalanceTextBlock"
                                   Margin="0,4,0,0"
                                   Foreground="#334155"
                                   Text="Số dư hiện tại: - VND" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="#E7F3FF"
                            BorderBrush="#97B8E2"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,8">
                        <TextBlock x:Name="TopupModalAmountTextBlock"
                                   Text="0 VND"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="#09248C"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="Bấm nhiều lần để cộng dồn. Không giới hạn trần mỗi lần nạp."
                               Foreground="DimGray"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="TopupModeAddButton"
                                Content="Nạp (+)"
                                Width="110"
                                Height="34"
                                Margin="0,0,8,0"
                                FontWeight="SemiBold"
                                Click="TopupModeAddButton_Click" />
                        <Button x:Name="TopupModeSubtractButton"
                                Content="Trừ (-)"
                                Width="110"
                                Height="34"
                                FontWeight="SemiBold"
                                Click="TopupModeSubtractButton_Click" />
                    </StackPanel>

                    <Grid Grid.Row="5" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Text="Nhập số tiền:" />
                        <TextBox x:Name="TopupCustomAmountTextBox"
                                 Grid.Column="1"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"
                                 KeyDown="TopupCustomAmountTextBox_KeyDown" />
                        <Button Grid.Column="2"
                                Content="Áp dụng"
                                Width="90"
                                Height="32"
                                Click="TopupApplyCustomAmountButton_Click" />
                    </Grid>

                    <StackPanel Grid.Row="6" Margin="0,0,0,10">
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <Button Content="1,000" Tag="1000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="2,000" Tag="2000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="3,000" Tag="3000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="4,000" Tag="4000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="5,000" Tag="5000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="6,000" Tag="6000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="7,000" Tag="7000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="8,000" Tag="8000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="9,000" Tag="9000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Background="#83D95C" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                        </UniformGrid>

                        <UniformGrid Columns="3">
                            <Button Content="10,000" Tag="10000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="20,000" Tag="20000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="30,000" Tag="30000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="40,000" Tag="40000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="50,000" Tag="50000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="60,000" Tag="60000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="70,000" Tag="70000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="80,000" Tag="80000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                            <Button Content="90,000" Tag="90000" Height="44" Margin="3" FontWeight="Bold" FontSize="16" Foreground="#FFEE00" Background="#D02217" BorderBrush="#282828" Click="TopupQuickAmountButton_Click" />
                        </UniformGrid>
                    </StackPanel>

                    <TextBlock x:Name="TopupModalErrorTextBlock"
                               Grid.Row="7"
                               Foreground="#B42318"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="TopupUndoButton"
                                Content="-"
                                Width="68"
                                Height="36"
                                Margin="0,0,8,0"
                                FontWeight="Bold"
                                Click="TopupUndoButton_Click" />
                        <Button x:Name="TopupClearButton"
                                Content="Xóa"
                                Width="90"
                                Height="36"
                                Margin="0,0,8,0"
                                FontWeight="SemiBold"
                                Click="TopupClearButton_Click" />
                        <Button Content="Hủy"
                                Width="90"
                                Height="36"
                                Margin="0,0,8,0"
                                Click="TopupCancelButton_Click" />
                        <Button x:Name="TopupSubmitButton"
                                Content="Nạp"
                                Width="90"
                                Height="36"
                                FontWeight="SemiBold"
                                Background="#79C959"
                                BorderBrush="#3F8A2E"
                                Click="TopupSubmitButton_Click" />
                    </StackPanel>
                </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>


