                        <!-- Row 4: Info Tip -->
                        <TextBlock Grid.Row="4" Text="💡 Khuyến mãi theo giờ giúp kích cầu giờ chơi trống, tự động áp dụng giảm giá trực tiếp vào phiên chơi khi thỏa mãn điều kiện khung giờ và ngày trong tuần." Foreground="#4B5563" FontSize="12" FontWeight="SemiBold" />
                    </Grid>
                </TabItem>
            </TabControl>
        </TabItem>

