                            <Slider x:Name="MachineTableFontSizeSlider"
                                    Width="260"
                                    Minimum="11"
                                    Maximum="30"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="MachineTableFontSizeSlider_ValueChanged" />
                            <TextBlock x:Name="MachineTableFontSizeValueTextBlock" Margin="10,0,0,0" VerticalAlignment="Center" Text="14" />
                        </StackPanel>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock VerticalAlignment="Center" Text="Padding menu chuột phải bảng Máy trạm:" Margin="0,0,8,0" />
