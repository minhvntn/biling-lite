                                    Padding="10,5"
                                    Click="ToggleServiceItemButton_Click"
                                    Content="Bật/Tắt dịch vụ" />
                        </Grid>

                        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                            <Button Margin="0,0,8,8" Padding="10,5" Click="OpenPcsWebButton_Click" Content="Mở web Máy trạm" />
                            <Button Margin="0,0,8,8" Padding="10,5" Click="OpenMembersWebButton_Click" Content="Mở web Hội viên" />
                            <Button Margin="0,0,8,8" Padding="10,5" Click="CheckBackendNowButton_Click" Content="Kiểm tra backend" />
                            <Button Margin="0,0,8,8" Padding="10,5" Click="RefreshAllDataButton_Click" Content="Tải lại toàn bộ dữ liệu" />
                        </WrapPanel>

                        <DataGrid x:Name="ServiceItemsDataGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternationCount="2"
                                  SelectionChanged="ServiceItemsDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding Name}" Width="1.5*" MinWidth="160" />
                                <DataGridTextColumn Header="Danh mục" Binding="{Binding Category}" Width="1.1*" MinWidth="120" />
                                <DataGridTextColumn Header="Giá" Binding="{Binding UnitPriceText}" Width="1*" MinWidth="110" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding ActiveText}" Width="1*" MinWidth="110" />
                                <DataGridTextColumn Header="Cập nhật" Binding="{Binding UpdatedAtText}" Width="1.3*" MinWidth="160" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="ServiceInfoTextBlock"
                                   Grid.Row="3"
                                   Margin="0,8,0,8"
                                   Text="Chưa tải danh sách dịch vụ" />

                        <TextBox x:Name="ServiceOutputTextBox"
                                 Grid.Row="4"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas"
                                 FontSize="13" />
                    </Grid>
                </TabItem>

                <TabItem Header="Khống chế website">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
