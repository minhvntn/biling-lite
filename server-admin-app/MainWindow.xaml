                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="WebFilterEnabledCheckBox"
                                      Content="Bật chặn website đen / nội dung người lớn trên máy trạm"
