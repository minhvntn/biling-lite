<Window x:Class="Server.Admin.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:svgc="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Server Manager Admin"
        Height="900"
        Width="1550"
        MinHeight="720"
        MinWidth="1240"
        PreviewMouseDown="Window_PreviewMouseDown"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1E5AA8" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#CFCFCF" />
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#E6E6E6" />
        <Thickness x:Key="MachineContextMenuItemPadding">12</Thickness>
        <sys:Double x:Key="MachineContextMenuFontSize">14</sys:Double>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F2F2F2" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E5AA8" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Foreground" Value="#1E5AA8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot"
                                Background="#F7F9FC"
                                BorderBrush="#CFCFCF"
                                BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#DC2626" />
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#DC2626" />
                                <Setter TargetName="TabRoot" Property="Background" Value="#FEF2F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#DC2626" />
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="#DC2626" />
                                <Setter TargetName="TabRoot" Property="Background" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>
    </Window.Resources>

    <Grid>
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="#1B4C86" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="Server Manager Billing [ADMIN]" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="HealthIndicator" Width="12" Height="12" Fill="#9ca3af" Margin="0,0,6,0" />
                        <TextBlock x:Name="HealthTextBlock" Foreground="White" Text="Backend: đang kiểm tra" />
                        <TextBlock Margin="10,0,8,0" Foreground="#93C5FD" Text="|" />
                        <TextBlock x:Name="ServerIpTextBlock" Foreground="#DBEAFE" Text="Server IP: -" />
                        <TextBlock Margin="10,0,8,0" Foreground="#93C5FD" Text="|" />
                        <Button x:Name="LogoutButton" 
                                Margin="4,0,0,0" 
                                Padding="8,2" 
                                Click="LogoutButton_Click" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                ToolTip="Đăng xuất">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" Foreground="White" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="Đăng xuất" Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0" FontSize="13" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabControl" Margin="8" SelectionChanged="MainTabControl_SelectionChanged">
                <TabItem x:Name="WorkstationsTab">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F5A5;" Margin="0,0,6,0" />
                            <TextBlock Text="Máy trạm" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Margin="0,0,6,0" Padding="10,5" Click="RefreshMachinesButton_Click" Content="Làm mới" />
                            <Button Grid.Column="1" Margin="0,0,6,0" Padding="10,5" Click="OpenMachineButton_Click" Content="Mở máy" />
                            <Button Grid.Column="2" Margin="0,0,6,0" Padding="10,5" Click="LockMachineButton_Click" Content="Khóa máy" />
                            <Button Grid.Column="3" Margin="0,0,6,0" Padding="10,5" Click="UnlockAllFilterButton_Click" Content="Bỏ lọc" />

                            <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="0,0,6,0" Text="Trạng thái:" />
                            <ComboBox x:Name="StatusFilterComboBox"
                                      Grid.Column="6"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="StatusFilterComboBox_SelectionChanged">
                                <ComboBoxItem Content="Tất cả" IsSelected="True" />
                                <ComboBoxItem Content="Đang sử dụng" />
                                <ComboBoxItem Content="Đang tắt" />
                                <ComboBoxItem Content="Sẵn sàng" />
                                <ComboBoxItem Content="Offline" />
                            </ComboBox>

                            <TextBlock Grid.Column="8" VerticalAlignment="Center" Margin="0,0,6,0" Text="Tìm máy:" />
                            <TextBox x:Name="SearchTextBox" Grid.Column="9" VerticalContentAlignment="Center" TextChanged="SearchTextBox_TextChanged" />

                            <TextBlock Grid.Column="11" VerticalAlignment="Center" x:Name="LastSyncTextBlock" Text="Đồng bộ: -" />
                        </Grid>

                        <DataGrid x:Name="MachinesDataGrid"
                                  Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternationCount="2"
                                  ColumnWidth="*"
                                  ContextMenuOpening="MachinesDataGrid_ContextMenuOpening"
                                  MouseDoubleClick="MachinesDataGrid_MouseDoubleClick"
                                  SelectionChanged="MachinesDataGrid_SelectionChanged">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="8,0" />
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="MachinesDataGridRow_PreviewMouseRightButtonDown" />
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu FontSize="{DynamicResource MachineContextMenuFontSize}">
                                    <ContextMenu.Resources>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Padding" Value="{DynamicResource MachineContextMenuItemPadding}" />
                                        </Style>
                                    </ContextMenu.Resources>
                                    <MenuItem x:Name="ContextOpenMachineMenuItem" Header="Mở máy" Click="ContextOpenMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextOpenGuestMachineMenuItem" Header="Đăng nhập trả tiền trước..." Click="ContextOpenGuestMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextAdminLoginMachineMenuItem" Header="Đăng nhập admin máy trạm" Click="ContextAdminLoginMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextLockMachineMenuItem" Header="Khóa máy" Click="ContextLockMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextTopupMachineMemberMenuItem" Header="Nạp tiền hội viên đang dùng máy..." Click="ContextTopupMachineMemberMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextRestartMachineMenuItem" Header="Khởi động lại máy trạm" Click="ContextRestartMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextShutdownMachineMenuItem" Header="Tắt máy trạm">
                                        <MenuItem x:Name="ContextShutdownSelectedMachineMenuItem"
                                                  Header="Tắt máy đã chọn"
                                                  Click="ContextShutdownSelectedMachineMenuItem_Click" />
                                        <MenuItem x:Name="ContextShutdownReadyMachinesMenuItem"
                                                  Header="Tắt các máy sẵn sàng"
                                                  Click="ContextShutdownReadyMachinesMenuItem_Click" />
                                    </MenuItem>
                                    <MenuItem x:Name="ContextControlMachineMenuItem" Header="Điều khiển máy trạm">
                                        <MenuItem x:Name="ContextControlCloseAppsMenuItem"
                                                  Header="Đóng ứng dụng..."
                                                  Click="ContextCloseAppsMenuItem_Click" />
                                        <MenuItem x:Name="ContextControlRemoteMenuItem"
                                                  Header="Điều khiển máy trạm (Live)"
                                                  Click="ContextRemoteControlMachineMenuItem_Click" />
                                        <MenuItem x:Name="ContextControlScreenshotMenuItem"
                                                  Header="Chụp màn hình máy trạm"
                                                  Click="ContextCaptureScreenshotMachineMenuItem_Click" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem x:Name="ContextPauseMachineMenuItem" Header="Tạm nghỉ máy trạm" Click="ContextPauseMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextResumeMachineMenuItem" Header="Tiếp tục sử dụng" Click="ContextResumeMachineMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextTransferMachineMenuItem" Header="Chuyển máy" Click="ContextTransferMachineMenuItem_Click" />
                                    <MenuItem x:Name="ContextAssignGroupMenuItem" Header="Chuyển nhóm máy">
                                        <MenuItem Header="Đang tải nhóm máy..." IsEnabled="False" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem x:Name="ContextViewMachineBillingMenuItem" Header="Xem thanh toán..." Click="ContextViewMachineBillingMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextSelectServiceMenuItem" Header="Chọn dịch vụ..." Click="ContextSelectServiceMenuItem_Click" />
                                    <MenuItem x:Name="ContextPayServiceMenuItem" Header="Thanh toán dịch vụ..." Click="ContextPayServiceMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextNotifyMachineMenuItem" Header="Gửi thông báo" Click="ContextNotifyMachineMenuItem_Click" />
                                    <Separator />
                                    <MenuItem Header="Làm mới danh sách" Click="ContextRefreshMachinesMenuItem_Click" />
                                    <Separator />
                                    <MenuItem x:Name="ContextControlCloseAllAppsMenuItem"
                                              Header="Đóng tất cả ứng dụng (Taskbar)"
                                              Click="ContextCloseAllAppsMenuItem_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#EAE8E3" />
                                    <Setter Property="Foreground" Value="#334155" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Padding" Value="8,6" />
                                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                                    <Setter Property="BorderBrush" Value="#CBD5E1" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Tên" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <svgc:SvgViewbox Source="{Binding StatusIconPath}"
                                                                 Width="32"
                                                                 Height="32"
                                                                 Margin="4,0,8,0"
                                                                 VerticalAlignment="Center"
                                                                 ToolTip="{Binding StatusIconToolTip}" />
                                                <TextBlock Text="{Binding Name}" 
                                                           VerticalAlignment="Center" 
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Tình trạng" Width="1.1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="0" Margin="-2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusCode}" Value="ONLINE">
                                                                <Setter Property="Background" Value="#ECFDF5" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCode}" Value="IN_USE">
                                                                <Setter Property="Background" Value="#EFF6FF" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCode}" Value="LOCKED">
                                                                <Setter Property="Background" Value="#FEF2F2" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusCode}" Value="OFFLINE">
                                                                <Setter Property="Background" Value="#DC2626" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsAdminSession}" Value="True">
                                                                <Setter Property="Background" Value="#FACC15" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="Gray" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="ONLINE">
                                                                    <Setter Property="Foreground" Value="#16A34A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="IN_USE">
                                                                    <Setter Property="Foreground" Value="#2563EB" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="LOCKED">
                                                                    <Setter Property="Foreground" Value="#DC2626" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="OFFLINE">
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsAdminSession}" Value="True">
                                                                    <Setter Property="Foreground" Value="#DC2626" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Người sử dụng" Width="1.1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UserName}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Bắt đầu" Width="0.95*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StartedAtText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Đã sử dụng" Width="0.95*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="0" Margin="-2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusCode}" Value="IN_USE">
                                                                <Setter Property="Background" Value="#FEF2F2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding UsedText}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#1E293B" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="IN_USE">
                                                                    <Setter Property="Foreground" Value="#DC2626" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Còn lại" Width="0.95*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="0" Margin="-2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusCode}" Value="IN_USE">
                                                                <Setter Property="Background" Value="#EFF6FF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding RemainingText}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#1E293B" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StatusCode}" Value="IN_USE">
                                                                    <Setter Property="Foreground" Value="#2563EB" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Tiền" Width="0.8*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MoneyText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Tiền dịch vụ" Width="0.9*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ServiceAmountText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Ngày" Width="0.95*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DateText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="IP" Width="1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IpAddress}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Nhóm" Width="1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding GroupName}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       x:Name="SelectionTextBlock"
                                       VerticalAlignment="Center"
                                       Text="Chưa chọn máy" />

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Border Margin="0,0,6,0" Padding="8,4" Background="#EEF2FF" CornerRadius="6">
                                    <TextBlock x:Name="SummaryTotalTextBlock" FontWeight="SemiBold" FontSize="13" Text="Tổng máy: 0" />
                                </Border>
                                <Border Margin="0,0,6,0" Padding="8,4" Background="#EEF6FF" CornerRadius="6">
                                    <TextBlock x:Name="SummaryMemberCountTextBlock" FontWeight="SemiBold" FontSize="12.5" Text="Tổng hội viên: 0" />
                                </Border>
                                <Border Margin="0,0,6,0" Padding="8,4" Background="#ECFDF3" CornerRadius="6">
                                    <TextBlock x:Name="SummaryUsingTextBlock" FontWeight="SemiBold" FontSize="13" Text="Đang sử dụng: 0" />
                                </Border>
                                <Border Margin="0,0,6,0" Padding="8,4" Background="#FEF2F2" CornerRadius="6">
                                    <TextBlock x:Name="SummaryLockedTextBlock" FontWeight="SemiBold" FontSize="13" Text="Đang tắt: 0" />
                                </Border>
                                <Border Padding="8,4" Background="#FFF7ED" CornerRadius="6">
                                    <TextBlock x:Name="SummaryMoneyTextBlock" FontWeight="SemiBold" FontSize="13" Text="Tiền tạm tính: 0" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem x:Name="MembersTab">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F464;" Margin="0,0,6,0" />
                            <TextBlock Text="Tài khoản" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="220" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
