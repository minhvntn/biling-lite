                                      Checked="LoyaltyPointsEnabledCheckBox_Checked"
                                      Unchecked="LoyaltyPointsEnabledCheckBox_Unchecked" />
                            
                            <StackPanel Margin="0,20,0,0">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Cài đặt máy trạm" />
