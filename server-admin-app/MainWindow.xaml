                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,5" />
                                    <Style.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#F7F7F7" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
