                                    Margin="8,0,8,0"
                                    Padding="10,5"
                                    Click="AddWebFilterDomainButton_Click"
                                    Content="Thêm domain" />
                            <Button Grid.Column="2"
                                    Margin="0,0,8,0"
                                    Padding="10,5"
                                    Click="RemoveSelectedWebFilterDomainButton_Click"
                                    Content="Xóa mục chọn" />
