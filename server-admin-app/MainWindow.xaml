                            <Button Grid.Column="2" Padding="10,5" Click="CreatePricingGroupButton_Click" Content="Thêm nhóm giá..." Margin="0,0,8,0" />
                            <Button Grid.Column="3" Padding="10,5" Click="UpdateSelectedGroupRateButton_Click" Content="Đổi giá nhóm đã chọn..." Margin="0,0,8,0" />
                            <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="Kéo máy từ bảng dưới thả vào nhóm bên trên để chuyển nhóm." Foreground="#555" />
                        </Grid>

                        <DataGrid x:Name="GroupSummaryDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  SelectionChanged="GroupSummaryDataGrid_SelectionChanged"
                                  AllowDrop="True"
                                  DragOver="GroupSummaryDataGrid_DragOver"
                                  Drop="GroupSummaryDataGrid_Drop"
                                  AlternationCount="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nhóm" Binding="{Binding GroupName}" Width="160" />
                                <DataGridTextColumn Header="Giá/giờ (VND)" Binding="{Binding HourlyRate, StringFormat={}{0:N0}}" Width="130" />
                                <DataGridTextColumn Header="Mặc định" Binding="{Binding IsDefaultText}" Width="90" />
                                <DataGridTextColumn Header="Tổng" Binding="{Binding Total}" Width="80" />
                                <DataGridTextColumn Header="Đang dùng" Binding="{Binding InUse}" Width="90" />
                                <DataGridTextColumn Header="Đang tắt" Binding="{Binding Locked}" Width="90" />
                                <DataGridTextColumn Header="Sẵn sàng" Binding="{Binding Online}" Width="90" />
                                <DataGridTextColumn Header="Ngoại tuyến" Binding="{Binding Offline}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid x:Name="GroupMachinesDataGrid"
                                  Grid.Row="2"
                                  Margin="0,8,0,0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  SelectionChanged="GroupMachinesDataGrid_SelectionChanged"
                                  PreviewMouseLeftButtonDown="GroupMachinesDataGrid_PreviewMouseLeftButtonDown"
                                  ContextMenuOpening="GroupMachinesDataGrid_ContextMenuOpening"
                                  MouseMove="GroupMachinesDataGrid_MouseMove"
                                  AlternationCount="2">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="GroupMachinesDataGridRow_PreviewMouseRightButtonDown" />
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="GroupMachinesAssignGroupMenuItem" Header="Chuyển nhóm máy">
                                        <MenuItem Header="Đang tải nhóm máy..." IsEnabled="False" />
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nhóm" Binding="{Binding GroupName}" Width="140" />
                                <DataGridTextColumn Header="Tên máy" Binding="{Binding MachineName}" Width="150" />
                                <DataGridTextColumn Header="Giá/giờ (VND)" Binding="{Binding HourlyRate, StringFormat={}{0:N0}}" Width="130" />
                                <DataGridTextColumn Header="Agent" Binding="{Binding AgentId}" Width="130" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusText}" Width="120" />
                                <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                <DataGridTextColumn Header="Lần cuối" Binding="{Binding LastSeenAtText}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="3" Margin="0,8,0,0" x:Name="GroupInfoTextBlock" Text="Nhóm mặc định đã được khởi tạo" />
                    </Grid>
                </TabItem>

                <TabItem Header="Dịch vụ">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="190" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="10,5"
                                    Click="RefreshServiceItemsButton_Click"
                                    Content="Làm mới" />

                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,6,0" Text="Tên dịch vụ:" />
                            <TextBox x:Name="ServiceNameTextBox" Grid.Column="2" VerticalContentAlignment="Center" />

                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="8,0,6,0" Text="Danh mục:" />
                            <TextBox x:Name="ServiceCategoryTextBox" Grid.Column="4" VerticalContentAlignment="Center" />

                            <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="8,0,6,0" Text="Giá (VND):" />
                            <TextBox x:Name="ServicePriceTextBox" Grid.Column="6" VerticalContentAlignment="Center" Text="15000" />

                            <Button Grid.Column="7"
