<Window x:Class="Server.Admin.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập Server Admin" Height="380" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="38,0,10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" x:Name="border">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Margin="40,0,10,0" VerticalAlignment="Center" Foreground="#9CA3AF" Visibility="Collapsed" x:Name="placeholder"/>
                                <TextBlock Text="👤" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#6B7280" FontSize="14" HorizontalAlignment="Left"/>
                                <ScrollViewer x:Name="PART_ContentHost" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="38,0,10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" x:Name="border">
                            <Grid>
                                <!-- Note: Watermark for PasswordBox is harder in pure XAML without a custom behavior, so we just use the icon -->
                                <TextBlock Text="🔒" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#6B7280" FontSize="14" HorizontalAlignment="Left"/>
                                <ScrollViewer x:Name="PART_ContentHost" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#3B82F6">
             <StackPanel VerticalAlignment="Center">
                 <TextBlock Text="💻" FontSize="32" Foreground="White" HorizontalAlignment="Center"/>
                 <TextBlock Text="SERVER MANAGER" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
             </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="30,35,30,30">
            <TextBox x:Name="UsernameTextBox" Style="{StaticResource ModernTextBox}" Tag="Tên đăng nhập" Margin="0,0,0,15" />
            <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" KeyDown="PasswordBox_KeyDown" Margin="0,0,0,10" />

            <TextBlock x:Name="ErrorTextBlock" Foreground="#EF4444" TextWrapping="Wrap" Margin="0,5,0,15" Visibility="Collapsed" TextAlignment="Center" FontSize="12" />
            
            <Button x:Name="LoginButton" Click="LoginButton_Click" Height="48" Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="ĐĂNG NHẬP" FontWeight="Bold" FontSize="14" Foreground="White"/>
            </Button>
            
            <TextBlock x:Name="LoadingTextBlock" Text="Vui lòng đợi..." Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Collapsed" FontSize="13" />
        </StackPanel>
    </Grid>
</Window>
